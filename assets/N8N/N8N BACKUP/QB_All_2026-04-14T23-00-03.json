    {
      "parameters": {
        "jsCode": "// Get the CustomField value\nconst customField = $input.first().json.Invoice.CustomField[0];\nconst stringValue = customField?.StringValue;\n\n// Determine invoice type\nlet invoiceType;\n\nif (stringValue === '2') {\n  invoiceType = 'Pro-Forma';\n} else {\n  // If value is '1', empty, null, or undefined - default to 'Invoice'\n  invoiceType = 'Invoice';\n}\n\n// Return in n8n format (array of objects with json property)\nreturn [\n  {\n    json: {\n      invoiceType: invoiceType\n    }\n  }\n];"
      },
