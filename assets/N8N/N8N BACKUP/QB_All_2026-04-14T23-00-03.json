    {
      "parameters": {
        "jsCode": "// Parse the outer data\nconst outerData = $input.first().json.data;\n\n// Parse the JSON string inside data\nconst events = JSON.parse(outerData);\n\n// Get the first event\nconst firstEvent = events[0];\n\n// Extract all properties separately\nconst specversion = firstEvent.specversion;\nconst id = firstEvent.id;\nconst source = firstEvent.source;\nconst type = firstEvent.type;\nconst time = firstEvent.time;\nconst intuitentityid = firstEvent.intuitentityid;\nconst intuitaccountid = firstEvent.intuitaccountid;\n\n// Return as n8n expects - array with json object\nreturn [\n  {\n    json: {\n      specversion,\n      id,\n      source,\n      type,\n      time,\n      intuitentityid,\n      intuitaccountid\n    }\n  }\n];"
      },
