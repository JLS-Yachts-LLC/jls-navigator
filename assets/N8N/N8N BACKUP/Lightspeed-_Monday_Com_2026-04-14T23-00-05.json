      "name": "Loop Over Items"
    },
    {
      "parameters": {
        "jsCode": "// Check if we hit the page limit (e.g., 1000 items)\nconst hasNextBatch = $json.data?.length === 1000;\n\nreturn [\n  {\n    json: {\n      continueFetching: hasNextBatch,\n      last_seen_version: $json.data?.[$json.data.length - 1]?.version ?? $json.last_seen_version\n    }\n  }\n];\n"
      },
