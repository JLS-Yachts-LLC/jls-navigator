      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// Prevent multiple updates in the same execution\nif (staticData.__cursor_updated_this_run) {\n  return items;\n}\n\nconst batchMax = Math.max(\n  ...items.map(i => i.json.__batch_version_max || 0)\n);\n\nif (batchMax > (staticData.last_seen_version || 0)) {\n  staticData.last_seen_version = batchMax;\n}\n\nstaticData.__cursor_updated_this_run = true;\n\nreturn items;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1472,
        0
      ],
      "id": "f901c2b8-20ee-4c6b-af42-2dfdce67c4fa",
      "name": "Save Last Seen Version"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const sale = item.json;\n\n  const saleDate = sale.sale_date ? new Date(sale.sale_date) : new Date();\n  const pad = n => String(n).padStart(2, '0');\n  const saleDateISO = `${saleDate.getFullYear()}-${pad(saleDate.getMonth()+1)}-${pad(saleDate.getDate())}`;\n\n  const columnValues = {\n    date4: { date: saleDateISO },\n    text_mky0p6ft: String(sale.invoice_number ?? 'N/A'),\n    numeric_mky04tna: sale.totals?.total_price ?? sale.total_price ?? 0,\n    text_mky0rpam: sale.status ?? 'Unknown'\n  };\n\n  return {\n    json: {\n      item_name: String(sale.invoice_number ?? 'N/A'),\n      column_values: JSON.stringify(columnValues),\n      __batch_version_max: sale.__batch_version_max\n    }\n  };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        0
      ],
      "id": "c4092919-b9f6-4e42-8527-902044946d31",
      "name": "Monday Mutation"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// Initialise timestamp cursor\nif (!staticData.last_seen_sale_time) {\n  staticData.last_seen_sale_time = '2023-01-01T00:00:00Z';\n}\n\nreturn [\n  {\n    json: {\n      last_seen_sale_time: staticData.last_seen_sale_time\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        0
      ],
      "id": "68a1b881-e88f-4ca8-90d4-1a8b30060fd0",
      "name": "Get Last Seen Version"
    },
    {
      "parameters": {
        "jsCode": "// Lightspeed returns { data: [...], meta: {...} }\n// We must explicitly extract data[]\n\nif (!Array.isArray($json.data)) {\n  throw new Error('Expected sales array at $json.data');\n}\n\nreturn $json.data.map(sale => ({\n  json: sale\n}));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
