      "parameters": {
        "jsCode": "const allProducts = [];\nconst inputItems = $input.all();\n\nfor (const item of inputItems) {\n  if (item.json.data && Array.isArray(item.json.data)) {\n    allProducts.push(...item.json.data);\n  }\n}\n\n// Filter to non-inventory only\nconst nonInventory = allProducts.filter(p => !p.track_inventory);\n\nconsole.log(`Total LS products fetched: ${allProducts.length}, Non-inventory: ${nonInventory.length}`);\nreturn [{ json: { ls_products: nonInventory, ls_count: nonInventory.length } }];"
      },
