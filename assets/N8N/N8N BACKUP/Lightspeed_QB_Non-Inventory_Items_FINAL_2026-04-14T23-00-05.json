    {
      "parameters": {
        "jsCode": "const allResults = $input.all();\nconst stats = { total: allResults.length, created: 0, failed: 0, errors: [] };\n\nfor (const item of allResults) {\n  if (item.json.status === 'success') {\n    stats.created++;\n  } else {\n    stats.failed++;\n    if (item.json.error) {\n      stats.errors.push({ item_name: item.json.item_name, lightspeed_id: item.json.lightspeed_id, error: item.json.error });\n    }\n  }\n}\n\nreturn [{ json: { execution_timestamp: new Date().toISOString(), summary: stats, message: `Non-inventory sync: ${stats.created} created, ${stats.failed} failed of ${stats.total}` } }];"
      },
