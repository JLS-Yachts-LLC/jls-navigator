    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\n\nlet lsProducts = [];\nlet qbItems = [];\n\nfor (const item of inputItems) {\n  if (item.json.ls_products) lsProducts = item.json.ls_products;\n  if (item.json.qb_items) qbItems = item.json.qb_items;\n}\n\nconsole.log(`Processing ${lsProducts.length} LS products against ${qbItems.length} QB items`);\n\nconst output = [];\nconst stats = { matched: 0, newItems: 0, invalidData: 0 };\n\nfor (const product of lsProducts) {\n  if (!product || !product.id) {\n    stats.invalidData++;\n    continue;\n  }\n  \n  const sku = (product.code || product.sku || \"\").toString().trim();\n  const name = (product.name || \"\").trim();\n  const description = (product.description || \"\").trim();\n  \n  if (!name) {\n    stats.invalidData++;\n    continue;\n  }\n  \n  const qbMatch = qbItems.find(qb => {\n    const qbSku = (qb.Sku || \"\").toString().trim();\n    const qbName = (qb.Name || \"\").toString().trim();\n    if (sku && qbSku === sku) return true;\n    if (qbName === name) return true;\n    return false;\n  });\n\n  if (qbMatch) {\n    stats.matched++;\n  } else {\n    stats.newItems++;\n  }\n\n  output.push({\n    json: {\n      lightspeed_id: product.id,\n      quickbooks_id: qbMatch?.Id || null,\n      sku: sku || null,\n      name: name,\n      description: description || null,\n      price: parseFloat(product.price || product.supply_price || 0),\n      cost: parseFloat(product.cost || product.supply_price || 0),\n      needs_creation: !qbMatch\n    }\n  });\n}\n\nconsole.log(`Stats - Matched: ${stats.matched}, New: ${stats.newItems}, Invalid: ${stats.invalidData}`);\nreturn output;"
      },
