    {
      "parameters": {
        "jsCode": "// Build QB Item matching Excel format\nconst itemData = {\n  Name: $json.name,\n  Type: \"Service\",\n  IncomeAccountRef: { value: \"85\" },  // UPDATE: Your Sales account ID\n  ExpenseAccountRef: { value: \"86\" }  // UPDATE: Your COGS account ID\n};\n\nif ($json.sku) itemData.Sku = $json.sku;\nif ($json.description) {\n  const desc = $json.description.substring(0, 4000);\n  itemData.Description = desc;\n}\nif ($json.price) itemData.UnitPrice = Number($json.price);\nif ($json.cost) itemData.PurchaseCost = Number($json.cost);\n\nreturn [{ json: { ItemData: itemData, lightspeed_id: $json.lightspeed_id, name: $json.name } }];"
      },
