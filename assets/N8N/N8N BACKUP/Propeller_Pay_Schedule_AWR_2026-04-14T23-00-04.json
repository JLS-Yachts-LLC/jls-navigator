    {
      "parameters": {
        "toRecipients": "={{322882755__items[]column_values[]text}}",
        "subject": "Welcome to Propeller Pay Payroll Services",
        "bodyContent": "=<!DOCTYPE html>\n<html>\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Second Request: AWR Information</title>\n  </head>\n  <body style=\"font-family: Arial, sans-serif; color: #333; line-height: 1.6;\">\n    <p>Dear Talentia Group,</p>\n\n    <p>\n      We are following up on our previous request regarding the \n      <strong>Agency Workers Regulations (AWR)</strong>. As part of our obligations, \n      we must confirm that temporary workers engaged through your agency receive \n      fair and equal treatment compared with permanent employees in similar roles \n      at Propeller Pay.\n    </p>\n\n    <p>\n      To complete this process for \n      <strong>{{322665531__candidate__firstName}} {{322665531__candidate__lastName}}, {{322665531__jobOrder__title}}</strong>, \n      we kindly remind you to complete <a target=\"_blank\" rel=\"noopener noreferrer\" href=\"https://form.jotform.com/252642929776068?workerName={{322665531__candidate__firstName}} {{322665531__candidate__lastName}}&amp;jobTitle={{322665531__jobOrder__title}}&amp;mondayid={{322791377__items[]id}}\">this form</a> provide the following details of the comparable permanent position:\n \n\n    <p>\n      We would be grateful if you could send this information as soon as possible to help us remain compliant. \n      If you require any clarification, please do not hesitate to get in touch.\n    </p>\n\n    <p>\n      Thank you for your prompt attention to this matter.\n    </p>\n\n    <p>Kind regards,<br>\n    <strong>Propeller Pay</strong></p>\n  </body>\n</html>\n",
        "additionalFields": {}
      },
