    {
      "parameters": {
        "toRecipients": "={{322882755__items[]column_values[]text}}",
        "subject": "Welcome to Propeller Pay Payroll Services",
        "bodyContent": "=<!DOCTYPE html>\n<html>\n  <body style=\"font-family: Arial, sans-serif; color: #333; line-height: 1.6;\">\n    <p>Dear Talentia Group,</p>\n\n    <p>\n      This is a final reminder regarding our request for information under the \n      <strong>Agency Workers Regulations (AWR)</strong>. We are required to hold accurate \n      details to confirm that temporary workers engaged through your agency receive fair \n      and equal treatment when compared with permanent employees in similar roles at Propeller Pay.\n    </p>\n\n    <p>\n      Specifically, we still require the following information for \n      <strong>{{322665531__candidate__firstName}} {{322665531__candidate__lastName}}, {{322665531__jobOrder__title}}</strong>:\n    </p>\n\n    <ul>\n      <li>Annual Salary</li>\n      <li>Standard Weekly Hours</li>\n      <li>Holiday Entitlement (including bank holidays)</li>\n      <li>Eligibility for Overtime, Bonus, or Benefits (with typical monetary values)</li>\n    </ul>\n\n    <p>\n      Please complete <a target=\"_blank\" rel=\"noopener noreferrer\" href=\"https://form.jotform.com/252642929776068?workerName={{322665531__candidate__firstName}} {{322665531__candidate__lastName}}&amp;jobTitle={{322665531__jobOrder__title}}&amp;mondayid={{322791377__items[]id}}\">this form</a> to provide this information. \n    </p>",
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [
        1360,
        224
      ],
      "id": "998890e5-e542-4a92-b7d1-f2c9b0fa4760",
      "name": "Send a message",
      "webhookId": "7f1b0be0-fe20-4304-9c24-a46a810adfc2",
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "7IaguepNlbcPCyIE",
          "name": "Microsoft Outlook account"
        }
      }
