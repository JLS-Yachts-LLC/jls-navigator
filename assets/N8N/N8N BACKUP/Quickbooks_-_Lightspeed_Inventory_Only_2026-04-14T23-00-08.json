      "name": "Update row(s)"
    },
    {
      "parameters": {
        "jsCode": "// Get the input\nconst input = $input.all();\n\n// Flatten all items\nlet output = [];\n\ninput.forEach(item => {\n  // Ensure QueryResponse.Item exists\n  if (item.json.QueryResponse && item.json.QueryResponse.Item) {\n    item.json.QueryResponse.Item.forEach(inv => {\n      output.push({\n        json: {\n          id: inv.Id,\n          qty: inv.QtyOnHand,\n          last_updated: inv.MetaData?.LastUpdatedTime || null\n        }\n      });\n    });\n  }\n});\n\nreturn output;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        944,
        -16
      ],
      "id": "6164f25b-1c9d-44d3-9eca-e04333825c4d",
      "name": "Prepare Lightspeed"
    },
    {
      "parameters": {
        "jsCode": "const lastSync = new Date($json[\"last_sync_time\"] || \"1970-01-01T00:00:00Z\");\n\nreturn $input.all().filter(item => {\n  const updated = new Date(item.json.last_updated);\n  return updated > lastSync;\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
        -16
      ],
      "id": "b5258b41-86b7-4c2e-b53d-498baa8e9606",
      "name": "Last Sync"
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => ({\n  json: {\n    itemId: item.json.id,\n    quantity: item.json.qty\n  }\n}));\n"
      },
