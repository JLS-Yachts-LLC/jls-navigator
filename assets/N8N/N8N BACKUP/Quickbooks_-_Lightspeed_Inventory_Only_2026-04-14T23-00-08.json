          "id": "LzsBKraDvi63Re6a",
          "name": "Waypoint - Quickbooks - Production"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const qbUpdatedAt = new Date($json.MetaData?.LastUpdatedTime);\nconst lightspeedLastSync = new Date($json.lightspeed_last_sync_time || 0); // fallback to epoch\n\n// Default: do NOT sync\nlet shouldSync = false;\n\n// Only sync if QB updated AFTER Lightspeed last sync\nif (\n  qbUpdatedAt instanceof Date &&\n  !isNaN(qbUpdatedAt) &&\n  lightspeedLastSync instanceof Date &&\n  !isNaN(lightspeedLastSync) &&\n  qbUpdatedAt > lightspeedLastSync\n) {\n  shouldSync = true;\n}\n\nreturn [\n  {\n    json: {\n      ...$json,\n      shouldSync,\n      sync_direction: shouldSync ? 'QB_TO_LIGHTSPEED' : 'IGNORE',\n      evaluated_at: new Date().toISOString(),\n    },\n  },\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        0
      ],
