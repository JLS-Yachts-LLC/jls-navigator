      },
      {
        "parameters": {
          "jsCode": "// Get the PaymentRefNum you want to filter by\n// const targetPaymentRefNum = \"$('Get a payment').first().json.PaymentRefNum\"; \nconst targetPaymentRefNum = $('Get a payment').first().json.Id\n\n// Get all input items from n8n\nconst items = $('Get a payment').all();\n\n// Extract payments from all items\nlet payments = [];\nfor (const item of items) {\n  if (item.json) {\n    if (Array.isArray(item.json)) {\n      payments.push(...item.json);\n    } else if (item.json.Id) {\n      // Add PaymentRefNum = Id (fallback)\n      item.json.PaymentRefNum = item.json.Id;\n      payments.push(item.json);\n    } else if (item.json.QueryResponse?.Payment) {\n      const paymentsData = item.json.QueryResponse.Payment;\n      payments.push(...(Array.isArray(paymentsData) ? paymentsData : [paymentsData]));\n    }\n  }\n}\n\n// Filter by PaymentRefNum\nconst filteredPayment = payments.find(payment => \n  String(payment.PaymentRefNum) === String(targetPaymentRefNum)\n);\n\n// If no payment found, return error\nif (!filteredPayment) {\n  return [{\n    json: {\n      error: \"No payment found with PaymentRefNum: \" + targetPaymentRefNum\n    }\n  }];\n}\n\n// Function to format date to YYYY/MM/DD\nconst formatDate = (dateString) => {\n  if (!dateString) return null;\n  const date = new Date(dateString);\n  const year = date.getFullYear();\n  const month = String(date.getMonth() + 1).padStart(2, '0');\n  const day = String(date.getDate()).padStart(2, '0');\n  return `${year}/${month}/${day}`;\n};\n\n// Function to split amount into Dhs and Fils\nconst splitAmount = (amount) => {\n  if (!amount) return { dhs: 0, fils: 0 };\n  const dhs = Math.floor(amount);\n  const fils = Math.round((amount - dhs) * 100);\n  return { dhs, fils };\n};\n\n// Split the total amount\nconst { dhs, fils } = splitAmount(filteredPayment.TotalAmt);\n\n// Extract only the required fields\nconst extractedData = {\n  Id: filteredPayment.Id,\n  SyncToken: filteredPayment.SyncToken,\n  CreateTime: formatDate(filteredPayment.MetaData?.CreateTime),\n  LastUpdatedTime: formatDate(filteredPayment.MetaData?.LastUpdatedTime),\n  TxnDate: formatDate(filteredPayment.TxnDate),\n  PaymentRefNum: filteredPayment.PaymentRefNum,\n  CurrencyRef: {\n    value: filteredPayment.CurrencyRef?.value,\n    name: filteredPayment.CurrencyRef?.name\n  },\n  TotalAmt: filteredPayment.TotalAmt,\n  Dhs: dhs,\n  Fils: fils,\n  UnappliedAmt: filteredPayment.UnappliedAmt,\n  CustomerRef: {\n    value: filteredPayment.CustomerRef?.value,\n    name: $input.first().json.GivenName\n  },\n  DisplayName: $input.first().json.DisplayName,\n  DepositToAccountRef: {\n    value: filteredPayment.DepositToAccountRef?.value\n  },\n  PaymentMethodRef: {\n    value: filteredPayment.PaymentMethodRef?.value\n  }\n};\n\nreturn [{\n  json: extractedData\n}];"
        },
