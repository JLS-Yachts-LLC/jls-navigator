        "jsonBody": "={\n  \"AttachableRef\": [\n    {\n      \"IncludeOnSend\": false,\n      \"EntityRef\": {\n        \"type\": \"Payment\",\n        \"value\": \"{{ $('Processing-1').item.json.Id }}\"\n      }\n    }\n  ],\n  \"FileName\": \"{{ $('DOC TO PDF 1').item.json.Files[0].FileName }}\",\n  \"ContentType\": \"application/pdf\",\n  \"Id\": \"{{ $('Upload to QBO').item.json.AttachableResponse[0].Attachable.Id }}\",\n  \"SyncToken\": \"{{ $('Upload to QBO').item.json.AttachableResponse[0].Attachable.SyncToken }}\"\n}",
